<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Zinsem_SignupApp.SignupPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Signup">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="Create Account"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>

            <Label Text="Username" />
            <Entry x:Name="UsernameEntry" Placeholder="Enter username" />

            <Label Text="Email" />
            <Entry x:Name="EmailEntry" Placeholder="Enter email" Keyboard="Email" />

            <Label Text="Password" />
            <Entry x:Name="PasswordEntry" Placeholder="Enter password" IsPassword="True" />

            <Label Text="Confirm Password" />
            <Entry x:Name="ConfirmPasswordEntry" Placeholder="Confirm password" IsPassword="True" />

            <Label x:Name="ErrorLabel"
                   TextColor="Red"
                   IsVisible="False"
                   FontAttributes="Bold" />

            <Button Text="Sign Up"
                    HeightRequest="52"
                    CornerRadius="16"
                    Clicked="OnSignUpClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>