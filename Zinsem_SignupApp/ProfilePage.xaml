<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Zinsem_SignupApp.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Profile">

    <VerticalStackLayout Padding="20" Spacing="14">

        <Label Text="Profile"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalOptions="Center"/>

        <Label x:Name="SuccessLabel"
               Text="Signup successful! ✅"
               FontAttributes="Bold"
               FontSize="18"
               HorizontalOptions="Center"/>

        <Frame CornerRadius="16" Padding="14">
            <VerticalStackLayout Spacing="10">
                <Label x:Name="UsernameLabel" FontSize="18" />
                <Label x:Name="EmailLabel" FontSize="18" />
            </VerticalStackLayout>
        </Frame>

        <Button Text="Sign Out"
                HeightRequest="52"
                CornerRadius="16"
                Clicked="OnSignOutClicked" />

    </VerticalStackLayout>
</ContentPage>